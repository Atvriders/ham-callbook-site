# Large data artifacts — must be sourced separately, not from git
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal
data/*.sqlite.bak*
data/uls.json
data/uls.json.*
data/uls_history.json
# Generated JSON artifacts (rebuilt by data-pipeline, not committed)
data/leaderboards.json
data/edition_diff.json
data/defunct_clubs.json
data/printed_lineage.json
data/phonetic_index.json
# Wave-3 address/households artifacts (large, rebuilt by build_address_index.py)
data/address_clusters.json
data/households.json
# Wave-3 submissions store (writable, survives DB swaps, never committed)
data/submissions.sqlite
data/submissions.sqlite-shm
data/submissions.sqlite-wal
# Wave-3 page cache (rendered PNG pages from pdftoppm, rebuilt on demand)
data/page_cache/
# Downloads directory (user-generated exports)
data/downloads/
# In-tree sqlite symlink/copy (never commit DB)
backend/app/*.sqlite
backend/app/*.sqlite-shm
backend/app/*.sqlite-wal

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
backend/.venv/
.venv/

# Node / Next
node_modules/
.next/
out/
dist/
*.tsbuildinfo
.npm/

# Local env
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
*~

# Backups + logs
*.bak
*.bak.*
*.log
/tmp/
